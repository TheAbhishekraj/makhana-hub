{
  "version": 2,
  "name": "makhana-hub",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "data.js", "use": "@vercel/static" },
    { "src": "render.js", "use": "@vercel/static" },
    { "src": "chatbot.js", "use": "@vercel/static" },
    { "src": "exports/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/exports/(.*)",
      "dest": "/exports/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
